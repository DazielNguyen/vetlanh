# ENV TEMPLATE — dùng file này để đối chiếu khi set vars trên Vercel
# Không điền giá trị thật vào file này

# URL backend API
NEXT_PUBLIC_API_URL=

# URL công khai của app (dùng cho metadata, OG tags)
NEXT_PUBLIC_APP_URL=

# Bật/tắt companion mascot app-wide (dashboard + chat). Mặc định bật; set=false để tắt
NEXT_PUBLIC_ENABLE_COMPANION=

# Thông tin ngân hàng cho VietQR
NEXT_PUBLIC_BANK_ACCOUNT=
NEXT_PUBLIC_BANK_ID=
NEXT_PUBLIC_BANK_NAME=

# Email admin, phân cách bằng dấu phẩy
ADMIN_USERS=
